{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/altf4-device-service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ServiceOptions": {
    "Port": 18500,
    "DeviceName": "KASA-01",
    "ApiUrl": "https://adisyon.synaptropic.com/api",
    "AdisyonWebUrl": "https://adisyon.synaptropic.com/login",
    "AutoOpenBrowser": true,
    "SyncIntervalSeconds": 30,
    "AdminUsername": "admin",
    "AdminPassword": "admin123",
    "BrowserRestrictions": {
      "DisableDevTools": true,
      "DisableContextMenu": true,
      "RestrictNavigationToAllowedDomains": true,
      "AllowedDomains": [
        "adisyon.synaptropic.com",
        "synaptropic.com",
        "127.0.0.1",
        "localhost"
      ],
      "HideNavigationControls": true,
      "EnableKioskFullScreen": true
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=altf4_device.db"
  },
  "AllowedHosts": "*"
}
